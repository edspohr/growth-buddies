{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(webp|mp4|webm|png|jpg|jpeg|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.growthbuddies.cl"
        }
      ],
      "destination": "https://growthbuddies.cl/$1",
      "permanent": true
    },
    { "source": "/metodologia/diagnostico", "destination": "/nosotros/", "permanent": true },
    { "source": "/metodologia/diseno", "destination": "/nosotros/", "permanent": true },
    { "source": "/metodologia/build", "destination": "/nosotros/", "permanent": true },
    { "source": "/metodologia/adopcion", "destination": "/nosotros/", "permanent": true },
    { "source": "/equipo/edmundo-spohr", "destination": "/nosotros/", "permanent": true },
    { "source": "/equipo/felipe-soto-santibanez", "destination": "/nosotros/", "permanent": true },
    { "source": "/soluciones/automatizacion-legal-emails", "destination": "/soluciones/#triaje-legal", "permanent": true },
    { "source": "/soluciones/gestion-documental-ip", "destination": "/soluciones/#docuagent", "permanent": true },
    { "source": "/soluciones/rendicion-gastos-ia", "destination": "/soluciones/#reembolso", "permanent": true },
    { "source": "/soluciones/catalogo.html", "destination": "/soluciones/", "permanent": true },
    { "source": "/servicios/automatizacion-inteligente", "destination": "/servicios/legal-tech/", "permanent": true }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
